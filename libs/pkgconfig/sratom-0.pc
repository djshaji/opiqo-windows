prefix=/mnt/sda/djshaji/projects/opiqo-win32
includedir=${prefix}/include
libdir=${prefix}/lib

Name: Sratom
Description: Small library for serializing LV2 atoms
Version: 0.6.22
Requires: lv2 >=  1.18.4, serd-0 >=  0.30.10, sord-0 >=  0.16.16
Libs: -L${libdir} -lsratom-0 -lm
Cflags: -I${includedir}/sratom-0 -DSRATOM_STATIC
